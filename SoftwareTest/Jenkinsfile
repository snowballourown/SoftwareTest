pipeline {
    agent any

    stages {
        stage('Connection Test') {
            steps {
                echo 'Jenkins webhook connection success!'
                sh 'pwd'
                sh 'ls -al'
            }
        }
    }

    post {
        success {
            echo 'Build succeeded.'
            mail(
                to: 'dlagudwns30@naver.com',        // 받는 사람
                subject: "✅ [SUCCESS] ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
                    빌드가 성공적으로 완료되었습니다!

                    Job     : ${env.JOB_NAME}
                    Build   : #${env.BUILD_NUMBER}
                    Status  : SUCCESS
                    URL     : ${env.BUILD_URL}
                """.stripIndent()
            )
        }
        failure {
            echo 'Build failed.'
        }
    }
}
